    "@react-router/cloudflare": "^7.13.1",
    "@react-router/dev": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@supabase/supabase-js": "^2.98.0",
    "isbot": "^5",
    "marked": "^17.0.2",
    "mermaid": "^11.12.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.0"
  }
