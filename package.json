{
  "name": "drew-portfolio",
  "version": "1.0.0",
  "description": "A portfolio site that starts with vanilla fundamentals and evolves as complexity demands it.",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "node scripts/fetch-content.js && react-router build",
    "build:local": "node --env-file=.env scripts/fetch-content.js && react-router build",
    "preview": "vite preview --outDir build/client",
    "lint": "eslint . --ext .js",
    "format": "prettier --write \"**/*.{js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,css,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soss-lesig/drew-portfolio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/soss-lesig/drew-portfolio/issues"
  },
  "homepage": "https://github.com/soss-lesig/drew-portfolio#readme",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "highlight.js": "^11.11.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "terser": "^5.46.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
